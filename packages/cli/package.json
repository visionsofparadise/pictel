{
  "name": "@pictel/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "pictel": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Matt Cavender",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visionsofparadise/pictel.git",
    "directory": "packages/cli"
  },
  "files": ["dist", "shell"],
  "scripts": {
    "check": "concurrently \"eslint . --fix --cache --format ../../agent-eslint.js\" \"tsc --noEmit --pretty false 2>&1 | node ../../agent-tsc.js\" \"tsc -p shell/tsconfig.json --noEmit --pretty false 2>&1 | node ../../agent-tsc.js\"",
    "unit": "vitest run --project unit",
    "integration": "vitest run --project integration",
    "build": "tsup"
  },
  "dependencies": {
    "@pictel/effects": "*",
    "pictel": "*",
    "puppeteer": "latest",
    "sharp": "latest",
    "vite": "latest",
    "@vitejs/plugin-react": "latest",
    "jiti": "latest",
    "commander": "latest"
  },
  "devDependencies": {
    "tsup": "latest",
    "vitest": "^4.1.4",
    "concurrently": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
