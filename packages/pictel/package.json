{
  "name": "pictel",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Matt Cavender",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visionsofparadise/pictel.git",
    "directory": "packages/pictel"
  },
  "scripts": {
    "check": "concurrently \"eslint . --fix --cache --format ../../agent-eslint.js\" \"tsc --noEmit --pretty false 2>&1 | node ../../agent-tsc.js\"",
    "integration": "vitest run --config vitest.integration.config.ts",
    "unit": "vitest run",
    "build": "tsup",
    "docs": "typedoc",
    "render:readme": "tsx scripts/render-readme.ts"
  },
  "dependencies": {
    "@zumer/snapdom": "latest",
    "lucide-react": "latest"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "alea": "^1.0.1",
    "concurrently": "latest",
    "playwright": "^1.59.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simplex-noise": "latest",
    "tsup": "latest",
    "tsx": "^4.20.3",
    "vitest": "latest"
  }
}
