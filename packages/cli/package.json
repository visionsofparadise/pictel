{
  "name": "@pictel/cli",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "pictel": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "shell"],
  "scripts": {
    "check": "concurrently \"eslint . --fix --cache --format ../../agent-eslint.js\" \"tsc --noEmit --pretty false 2>&1 | node ../../agent-tsc.js\" \"tsc -p shell/tsconfig.json --noEmit --pretty false 2>&1 | node ../../agent-tsc.js\"",
    "unit": "vitest run",
    "build": "tsup"
  },
  "dependencies": {
    "@pictel/effects": "*",
    "pictel": "*",
    "puppeteer": "latest",
    "sharp": "latest",
    "vite": "latest",
    "@vitejs/plugin-react": "latest",
    "jiti": "latest",
    "commander": "latest"
  },
  "devDependencies": {
    "tsup": "latest",
    "vitest": "latest",
    "concurrently": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
