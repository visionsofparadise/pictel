{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "check": {
      "dependsOn": ["^check"],
      "inputs": ["src/**", "./tsconfig.json"],
      "outputs": []
    },
    "docs": {
      "dependsOn": [],
      "inputs": ["src/**", "typedoc.json", "clean-docs.mjs"],
      "outputs": ["README.md"]
    },
    "build": {
      "dependsOn": ["^build", "check", "docs"],
      "inputs": ["src/**", "./tsconfig.json", "./package.json"],
      "outputs": ["dist/**"]
    },
    "unit": {
      "dependsOn": ["check"]
    },
    "lint": {
      "dependsOn": []
    }
  }
}
